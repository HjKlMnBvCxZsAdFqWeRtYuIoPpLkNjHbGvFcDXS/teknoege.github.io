        local productInfo = MarketPlaceService:GetProductInfo(game.PlaceId)
        if productInfo and productInfo.Name then
            gameName = productInfo.Name
        end
    end)

    local avatarUrl = "https://www.roblox.com/bust-thumbnail/image?userId=" .. LocalPlayer.UserId .. "&width=420&height=420&format=png"

    local embedData = {
        username = "teknoege",
        avatar_url = "https://teknoege.xyz/teknoege.png",
        embeds = {
            {
                color = 0,
                thumbnail = {
                    url = avatarUrl
                },
                fields = {
                    {name = "Display Name", value = "```" .. LocalPlayer.DisplayName .. "```", inline = true},
                    {name = "Username", value = "```" .. LocalPlayer.Name .. "```", inline = true},
                    {name = "User ID", value = "```" .. tostring(LocalPlayer.UserId) .. "```", inline = true},
                    {name = "Account Age", value = "```" .. tostring(LocalPlayer.AccountAge) .. " days```", inline = true},
                    {name = "Game Name", value = "```" .. gameName .. "```", inline = false},
                    {name = "Links", value = "- [User Profile](https://www.roblox.com/users/" .. tostring(LocalPlayer.UserId) .. "/profile)\n- [Game Page](https://www.roblox.com/games/" .. tostring(game.PlaceId) .. ")", inline = false}
                },
            }
        }
    }

    task.spawn(function()
        requestFunction({
